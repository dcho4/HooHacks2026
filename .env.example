# Auth0 Configuration
# Create a Single Page Application at https://manage.auth0.com
# Enable email verification: Authentication > Database > Settings > Requires Verification
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id_here
VITE_AUTH0_AUDIENCE=https://babyboo-api

# Backend API URL
VITE_API_URL=http://localhost:3001
